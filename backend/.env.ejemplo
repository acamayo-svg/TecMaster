# Variables para el proyecto Backend en Vercel (Settings → Environment Variables).
# No subas archivos .env al repositorio. Configura todo en el panel de Vercel.

# PostgreSQL (Supabase: Connection string → host, port, database, user, password)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# CORS: URL del frontend en Vercel (sin barra final)
CORS_ORIGIN=https://tu-frontend.vercel.app
